# Names only - copy to .env and fill in real values. The real .env is gitignored.

# Data sources
ACADEMIC_INSIGHTS_API_KEY=
SCORECARD_API_KEY=

# Postgres
DB_DSN=postgresql://user:pass@localhost/colleges

# Agent
AGENT_MODEL=haiku
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# API auth - comma-separated bearer tokens accepted by /chat
API_TOKENS=tester1-secret,tester2-secret
